package acp

import (
    . "martianoff/gala/test"
    . "martianoff/gala/std"
    . "martianoff/gala/go_interop"
)

// ----- content-hash identity ------------------------------------------------

// Re-deriving an Envelope from byte-identical inputs yields the SAME Id. This
// is the property the idempotent decoder and the Ledger rest on.
func TestNewEnvelope_DeterministicId(t T) T {
    val a = NewEnvelope("_lead", "Felix", "dispatch", "build the parser", 0)
    val b = NewEnvelope("_lead", "Felix", "dispatch", "build the parser", 0)
    return Eq(t, a.Id, b.Id)
}

// Each identity field participates in the hash: perturbing any one of
// (Sender, Recipient, Kind, Body, Epoch) changes the Id.
func TestNewEnvelope_EveryFieldAffectsId(t T) T {
    val base = NewEnvelope("_lead", "Felix", "dispatch", "body", 0)
    val t1 = NotEq(t,  base.Id, NewEnvelope("_user", "Felix", "dispatch", "body", 0).Id)
    val t2 = NotEq(t1, base.Id, NewEnvelope("_lead", "Mira",  "dispatch", "body", 0).Id)
    val t3 = NotEq(t2, base.Id, NewEnvelope("_lead", "Felix", "consult",  "body", 0).Id)
    val t4 = NotEq(t3, base.Id, NewEnvelope("_lead", "Felix", "dispatch", "body2", 0).Id)
    return    NotEq(t4, base.Id, NewEnvelope("_lead", "Felix", "dispatch", "body", 1).Id)
}

// Field-boundary disambiguation: ("a","bc") must not collide with ("ab","c").
// Per-field hashing makes this hold without delimiters.
func TestNewEnvelope_NoFieldBoundaryCollision(t T) T {
    val x = NewEnvelope("a", "bc", "dispatch", "", 0)
    val y = NewEnvelope("ab", "c", "dispatch", "", 0)
    return NotEq(t, x.Id, y.Id)
}

// The Id is a fixed-width 16-hex-digit string (two 32-bit words).
func TestNewEnvelope_IdShape(t T) T {
    val m = NewEnvelope("_lead", "Felix", "dispatch", "body", 0)
    return Eq(t, len(ToRunes(m.Id)), 16)
}

// Defaults: fresh envelope is attempt 1, no causal parent.
func TestNewEnvelope_Defaults(t T) T {
    val m = NewEnvelope("_lead", "Felix", "dispatch", "body", 0)
    val t1 = Eq(t, m.Attempt, 1)
    return IsNone(t1, m.InReplyTo)
}

// Metadata (causal link, attempt) is NOT identity — threading a reply or
// bumping the attempt must keep the Id stable so the Ledger collapses a
// redelivered message to one admitted entry.
func TestWithReplyTo_PreservesId(t T) T {
    val m = NewEnvelope("Felix", "_lead", "finished", "done", 0)
    val r = WithReplyTo(m, "parent-id")
    val t1 = Eq(t, r.Id, m.Id)
    return IsSome(t1, r.InReplyTo)
}

func TestWithAttempt_PreservesId(t T) T {
    val m = NewEnvelope("_lead", "Felix", "dispatch", "body", 0)
    val r = WithAttempt(m, 3)
    val t1 = Eq(t, r.Id, m.Id)
    return Eq(t1, r.Attempt, 3)
}

// Epoch is the stale-redelivery defence: the same logical dispatch in a later
// epoch is a DIFFERENT message, so a late duplicate of the previous turn cannot
// be mistaken for the live one.
func TestEpoch_DistinguishesRedispatch(t T) T {
    val e0 = NewEnvelope("_lead", "Felix", "dispatch", "same task", 0)
    val e1 = NewEnvelope("_lead", "Felix", "dispatch", "same task", 1)
    return NotEq(t, e0.Id, e1.Id)
}

// ContentHash is the same deterministic digest NewEnvelope stamps on Id.
func TestContentHash_MatchesNewEnvelopeId(t T) T {
    val m = NewEnvelope("_lead", "Felix", "dispatch", "body", 2)
    return Eq(t, m.Id, ContentHash("_lead", "Felix", "dispatch", "body", 2))
}
